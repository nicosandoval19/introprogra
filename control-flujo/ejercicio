

def es_palindromo(texto):
    lista=[]
    lista_al_reves= lista[::-1]
    for letra in texto:
        if letra != " ":
            lista.append(letra)
            lista_al_reves=lista[::-1]
        
    print(lista)
    print(lista_al_reves)
    print(lista_al_reves==lista)
        
